<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite parallel="tests" thread-count="5" name="Suite">
<listeners>
<listener class-name="Testcomponents.Listeners"></listener>
</listeners>
  <test thread-count="5" name="Submit Order Test">
    <classes>
      <class name="Testing.SubmitOrder"/>
    </classes>
  </test> <!-- Test -->
  <test thread-count="5" name="Error Validation Test">
    <classes>
      <class name="Testing.Errorvalidation"/>
      <class name="Testing.SubmitOrder"/>
    </classes>
  </test>
  <test thread-count="5" name="SmokeTest">
    <classes>
      <class name="Testing.SmokeTest"/>
    </classes>
  </test>
</suite> <!-- Suite -->
